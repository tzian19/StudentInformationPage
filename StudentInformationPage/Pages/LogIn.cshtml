@page
@model StudentInformationPage.Pages.LogInModelModel
@{
    Layout = "~/Pages/Shared/_LogInLayout.cshtml";
}


<div class="d-flex align-items-center justify-content-center vh-100"
     style="background: linear-gradient(170deg, rgba(0,0,0,1) 10%, rgba(152,251,203) 85%);">
    <div class="card glass-card shadow-xl p-4 rounded-3" style="max-width: 400px; width: 100%;">
        <h3 class="text-center mb-4 text-white fw-bold">Login</h3>

        <div class="user-icon-container text-center mb-4">
            <img class="user-icon" src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQF02Jj8T2t7PdkytAw42HDuuSz7yXguKn8Lg&s"
        </div>
        

        <form method="post" id="loginform" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Credential.Username" class="form-control glass-input" placeholder="Username" />
                <label asp-for="Credential.Username" class="text-white-50"></label>
                <span class="text-danger small" asp-validation-for="Credential.Username"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Credential.Password" type="password" class="form-control glass-input" placeholder="Password" />
                <label asp-for="Credential.Password" class="text-white-50"></label>
                <span class="text-danger small" asp-validation-for="Credential.Password"></span>
            </div>

            <button type="submit" class="btn glass-btn w-100 py-2 fw-semibold">Sign In</button>
        </form>
    </div>
</div>

<!-- Toast container -->
<div aria-live="polite" aria-atomic="true" class="position-relative">
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        @if (Model.LoginFailed)
        {
            <div class="toast align-items-center text-white bg-danger border-0" role="alert" data-bs-autohide="true" data-bs-delay="3000">
                <div class="d-flex">
                    <div class="toast-body">
                        Invalid username or password.
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Automatically show toast if it exists

        document.addEventListener("DOMContentLoaded", function () {
            var toastEl = document.querySelector(".toast");
            if (toastEl) {
                var toast = new bootstrap.Toast(toastEl, {
                    autohide: true,
                    delay: 3000 // 3 seconds
                });
                toast.show();
            }
        });
       

    </script>
}
